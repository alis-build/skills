//   NewLROTool(
//     "REPLACE_WITH_lro_snake_case",
//     pb.ToolsService_REPLACE_WITH_LRO_RPC_PascalCase_FullMethodDescription,
//     toolsService.REPLACE_WITH_LRO_RPC_PascalCase,
//   ),
