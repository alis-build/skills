# Cloud Run container args and env vars for the scheduler on the agent service.
# Dockerfile CMD must use the same sublauncher args as Cloud Run.
#
# Mirror application env vars on google_vertex_ai_reasoning_engine.spec.deployment_spec
# (see agent.tf.deployment_spec-envs.example). GOOGLE_CLOUD_* vars are Cloud Run only.
#
# Only include sublauncher args for sublaunchers the agent actually uses.
# The scheduler does not depend on webui, api, lro, or agui.

# Minimal (scheduler only):
containers {
  command = ["/app/main"]
  args    = ["web", "-port", "8080", "scheduler", "-app_name=my.neuron.v1"]

  env {
    name  = "ALIS_OS_PROJECT"
    value = var.ALIS_OS_PROJECT
  }
  env {
    name  = "ALIS_REGION"
    value = var.ALIS_REGION
  }
  env {
    name  = "ALIS_PROJECT_NR"
    value = var.ALIS_PROJECT_NR
  }
  env {
    name  = "ALIS_MANAGED_SPANNER_PROJECT"
    value = var.ALIS_MANAGED_SPANNER_PROJECT
  }
  env {
    name  = "ALIS_MANAGED_SPANNER_INSTANCE"
    value = var.ALIS_MANAGED_SPANNER_INSTANCE
  }
  env {
    name  = "ALIS_MANAGED_SPANNER_DB"
    value = var.ALIS_MANAGED_SPANNER_DB
  }
  env {
    name  = "AGENT_SERVICE_URL"
    value = local.agent_service_url
  }
  # Cloud Run only — do not add to agent.tf deployment_spec (Reasoning Engine injects these).
  env {
    name  = "GOOGLE_CLOUD_PROJECT"
    value = var.ALIS_PROJECT_NR
  }
  env {
    name  = "GOOGLE_CLOUD_LOCATION"
    value = var.ALIS_REGION
  }
  env {
    name  = "GOOGLE_CLOUD_AGENT_ENGINE_ID"
    value = google_vertex_ai_reasoning_engine.reasoning_engine.id
  }
}

# Dockerfile (must match args above):
# CMD ["/app/main", "web", "-port", "8080", "scheduler", "-app_name=my.neuron.v1"]

# Typical (with other sublaunchers the agent uses):
# args = ["web", "-port", "8080", "webui", "-api_server_address=/api", "api", "lro", "scheduler", "-app_name=my.neuron.v1"]
