// Capability: Scheduler service bootstrap
// Contract: Export var Service *schedulerservice.SchedulerService and func MustInitScheduler(ctx).
//           Uses central NeuronId for Cloud Tasks queue ({NeuronId}-a2a-scheduler) and Spanner
//           table prefix. Reads ALIS_MANAGED_SPANNER_*, ALIS_OS_PROJECT, ALIS_REGION, AGENT_SERVICE_URL.
// Greenfield default path: internal/scheduler/scheduler.go

package scheduler

import (
	"context"
	"fmt"
	"strings"

	"REPLACE_WITH_YOUR_MODULE/internal/info"
	schedulerext "go.alis.build/a2a/extension/scheduler"
	schedulerservice "go.alis.build/a2a/extension/scheduler/service"
	"go.alis.build/alog"
	"go.alis.build/utils/env"
)

var Service *schedulerservice.SchedulerService

func InitScheduler(ctx context.Context) error {
	spannerProject := env.MustGet("ALIS_MANAGED_SPANNER_PROJECT")
	spannerInstance := env.MustGet("ALIS_MANAGED_SPANNER_INSTANCE")
	spannerDatabase := env.MustGet("ALIS_MANAGED_SPANNER_DB")

	project := env.MustGet("ALIS_OS_PROJECT")
	tablePrefix := strings.ReplaceAll(project, "-", "_") + "_" + strings.ReplaceAll(info.NeuronId, "-", "_")

	var err error
	Service, err = schedulerservice.NewSchedulerService(ctx, &schedulerservice.SchedulerServiceConfig{
		SpannerProject:    spannerProject,
		SchedulingProject: project,
		SchedulingQueue:   info.NeuronId + "-a2a-scheduler",
		SchedulingRegion:  env.MustGet("ALIS_REGION"),
		Instance:          spannerInstance,
		ServiceAccount:    fmt.Sprintf("alis-build@%s.iam.gserviceaccount.com", project),
		Audience:          env.MustGet("AGENT_SERVICE_URL"),
		Database:          spannerDatabase,
		DatabaseRole:      "",
		TablePrefix:       tablePrefix,
		TargetUrl:         env.MustGet("AGENT_SERVICE_URL") + schedulerext.HandlerPath,
	})
	if err != nil {
		return fmt.Errorf("instantiating scheduler service: %w", err)
	}

	return nil
}

func MustInitScheduler(ctx context.Context) {
	if err := InitScheduler(ctx); err != nil {
		alog.Fatalf(ctx, "%v", err)
	}
}
