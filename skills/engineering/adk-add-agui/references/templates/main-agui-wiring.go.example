// Wire into agent main.go — add AG-UI sublauncher to the existing web launcher stack.
//
// Only the import and sublauncher marked REQUIRED are needed for minimal AG-UI (SSE only).
// Other sublaunchers (webui, api, lro, a2a, scheduler, agentengine) are independent —
// include them only if the agent uses them.

import (
	// "alis.<product>.<agent>.v1.agent/internal/agui/history" // when WithThreadService
	webagui "go.alis.build/adk/launchers/agui" // REQUIRED for AG-UI
	// weblro "go.alis.build/adk/launchers/lro"  // only if LRO is used
	web "google.golang.org/adk/cmd/launcher/web"
	"google.golang.org/adk/cmd/launcher/universal"
	// "google.golang.org/grpc" // when WithGRPCRegistrar for thread history
	// ... other launcher imports ...
)

// ADK root agent name (llmagent.Config.Name). Same as adkAppName in scheduler/console wiring.
const adkAppName = "REPLACE_WITH_ADK_APP_NAME"

func main() {
	ctx := context.Background()
	// ... agent config ...

	// When thread history / threads are needed:
	// grpcServer := grpc.NewServer()
	// mux.HandleGRPC(grpcServer)

	// Only include sublaunchers the agent actually uses.
	// AG-UI requires: web + agui. No other sublauncher dependencies.
	l := universal.NewLauncher(web.NewLauncher(
		// webagentengine.NewLauncher(agentEngineID),  // only if using Agent Engine
		// webui.NewLauncher(),                         // only if serving the ADK web UI
		// webapi.NewLauncher(),                        // only if using /api endpoints
		// weba2a.NewLauncher(),                        // only if using A2A protocol
		// weblro.NewLauncher(weblro.WithServiceID(lroServiceID), weblro.WithLROClient(tools.LRO)),
		webagui.NewLauncher(adkAppName, webagui.WithCORS(webagui.CORSConfig{})), // REQUIRED (minimal)
		// Thread history — user says "thread history", "threads", "thread metadata":
		// webagui.NewLauncher(adkAppName,
		// 	webagui.WithThreadService(history.Service),
		// 	webagui.WithCORS(webagui.CORSConfig{}),
		// 	webagui.WithGRPCRegistrar(grpcServer),
		// ),
	))
	// l.Execute(ctx, launcherConfig, os.Args[1:])
}

// Deployment CLI args must include "agui".
// Dockerfile: CMD ["/app/main", "web", "-port", "8080", "agui"]
// Cloud Run:  args = ["web", "-port", "8080", "agui"]
// Add other sublauncher args (webui, api, lro, scheduler) only if used.
