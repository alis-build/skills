	if err != nil {
		return nil, err
	}

	return &{{ .CollectionId }}Table[*{{ .ImportAlias }}.{{ .ResourceName }}]{
		tableName:    tableName,
		client:       spannerClient,
		filterParser: parser,
	}, nil
}

func (db *{{ .CollectionId }}Table[R]) WritePolicy(ctx context.Context, name string, policy *iampb.Policy) error {
	// Insert the row into Spanner
	mutation := spanner.Update(db.tableName, []string{"key", "Policy"}, []interface{}{name, policy})
	if _, err := db.client.Apply(ctx, []*spanner.Mutation{mutation}); err != nil {
		return database.SpannerErrorToStatus(err)
	}

	return nil
}

func (db *{{ .CollectionId }}Table[R]) BatchWritePolicies(ctx context.Context, names []string, policies []*iampb.Policy) error {
	// Validate that names and policies have the same length
	if len(names) != len(policies) {
		return status.Errorf(codes.InvalidArgument, "names and policies must have the same length")
	}

	// Create a slice to hold the mutations
	mutations := make([]*spanner.Mutation, len(names))

	// Iterate over the names, resources, and policies to create ResourceRows and mutations
	for i, name := range names {
		mutations[i] = spanner.Update(db.tableName, []string{"key", "Policy"}, []interface{}{name, policies[i]})
	}

	// Apply the mutations to Spanner
	if _, err := db.client.Apply(ctx, mutations); err != nil {
		return database.SpannerErrorToStatus(err)
	}

	return nil
}

