func (db *{{ .CollectionId }}Table[R]) BatchRead(ctx context.Context, names []string) ([]database.ResourceRow[R], []string, error) {
	// If no names are provided, return an empty slice
	if len(names) == 0 {
		return []database.ResourceRow[R]{}, nil, nil
	}

	// Create a slice of keys for the batch read
	keySets := make([]spanner.KeySet, len(names))
	for i, name := range names {
		keySets[i] = &spanner.Key{name}
	}

	// Read the rows from Spanner
	it := db.client.Single().Read(ctx, db.tableName, spanner.KeySets(keySets...), []string{"key", "{{ .ResourceName }}", "Policy"})
	defer it.Stop()

	// Create a slice to hold the ResourceRows
	resourceRowMap := make(map[string]*SpannerResourceRow[R])
	// Iterate over the results and construct ResourceRows
	for {
		row, err := it.Next()
		if errors.Is(err, iterator.Done) {
			break // No more rows
		}
		if err != nil {
			return nil, nil, database.SpannerErrorToStatus(err)
		}

		var key string
		if err := row.ColumnByName("key", &key); err != nil {
			return nil, nil, database.SpannerErrorToStatus(err)
		}

		resourceRow := &SpannerResourceRow[R]{
			key:           key,
			resourceTable: db,
		}

		// Unmarshal the resource from the row
		resource := spanner.NullProtoMessage{
			ProtoMessageVal: &{{ .ImportAlias }}.{{ .ResourceName }}{},
		}
		if err := row.ColumnByName("{{ .ResourceName }}", &resource); err != nil {
			return nil, nil, database.SpannerErrorToStatus(err)
		}
		if resource.Valid {
			resourceRow.resource = resource.ProtoMessageVal.(R)
		}

		// Unmarshal the policy from the row
		policy := spanner.NullProtoMessage{
			ProtoMessageVal: &iampb.Policy{},
		}
		if err := row.ColumnByName("Policy", &policy); err != nil {
			return nil, nil, database.SpannerErrorToStatus(err)
		}
		if policy.Valid {
			resourceRow.policy = policy.ProtoMessageVal.(*iampb.Policy)
		}

		resourceRowMap[key] = resourceRow
	}

	// Create a slice to hold the ResourceRows
	resourceRows := make([]database.ResourceRow[R], len(names))
	// Create a slice of names that were not found
	var notFoundNames []string
	for i, name := range names {
		if row, found := resourceRowMap[name]; found {
			resourceRows[i] = row
		} else {
			resourceRows[i] = nil
			notFoundNames = append(notFoundNames, name)
		}
	}

	return resourceRows, notFoundNames, nil
}

