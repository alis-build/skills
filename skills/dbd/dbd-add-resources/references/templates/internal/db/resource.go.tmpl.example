		// DatabaseRole:         strings.ReplaceAll(os.Getenv("ALIS_OS_PROJECT"), "-", "_")
	}
	spannerClient, err := spanner.NewClientWithConfig(ctx, fmt.Sprintf("projects/%s/instances/%s/databases/%s", spannerProject, spannerInstance, spannerDatabase), clientConfig)
	if err != nil {
