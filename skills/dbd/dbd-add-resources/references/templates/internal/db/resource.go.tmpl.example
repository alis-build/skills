func (db *{{ .CollectionId }}Table[R]) List(ctx context.Context, parent string, pageSize int32, pageToken string, filter string, orderBy string) ([]database.ResourceRow[R], string, error) {

	statement := spanner.NewStatement(fmt.Sprintf("SELECT `key`,`{{ .ResourceName }}`,`Policy` FROM %s", db.tableName))

	if parent != "" {
		statement.SQL += fmt.Sprintf(" WHERE STARTS_WITH(%s,@parent)", "key")
		statement.Params["parent"] = parent
	}

	// Append filter to the statement
	if filter != "" {
		filterStmt, err := db.filterParser.Parse(filter)
		if err != nil {
			return nil, "", err
		}

		// If the parent is not empty, we need to add an AND condition
		if parent != "" {
			statement.SQL += " AND "
		} else {
			// If the parent is empty, we start with WHERE
			statement.SQL += " WHERE "
		}

		// Append the filter SQL and parameters
		statement.SQL += filterStmt.SQL
		for k, v := range filterStmt.Params {
			statement.Params[k] = v
		}
	}

	// Add sorting conditions if provided
	if orderBy != "" {
		order, err := ordering.NewOrder(orderBy)
		if err != nil {
			return nil, "", err
		}
		sortOrder := order.SortOrder()

		statement.SQL += " ORDER BY "

		sortColumns := make([]string, 0, len(sortOrder))
		for column, columnOrder := range sortOrder {
			sortColumns = append(sortColumns, fmt.Sprintf("%s %s", column, columnOrder.String()))
		}

		statement.SQL += strings.Join(sortColumns, ", ")
	}
	// Add limit if provided
	limit := 100
	if pageSize > 0 {
		limit = int(math.Min(float64(pageSize), float64(limit)))
	}
	statement.SQL += fmt.Sprintf(" LIMIT %v", limit)

	// Add offset if page token is provided
	var offset int64
	if pageToken != "" {
		offsetBytes, err := base64.StdEncoding.DecodeString(pageToken)
		if err != nil {
			return nil, "", status.Errorf(codes.Internal, "decode page token: %s", err.Error())
		}

		offset, err = strconv.ParseInt(string(offsetBytes), 10, 64)
		if err != nil {
			return nil, "", status.Errorf(codes.Internal, "parse page token: %s", err.Error())
		}
		statement.SQL += fmt.Sprintf(" OFFSET %v", offset)
	}

	it := db.client.Single().Query(ctx, statement)
	defer it.Stop()

	var resourceRows []database.ResourceRow[R]
	for {
		row, err := it.Next()
		if errors.Is(err, iterator.Done) {
			break // No more rows
		}
		if err != nil {
			return nil, "", database.SpannerErrorToStatus(err)
		}

		var key string
		if err := row.ColumnByName("key", &key); err != nil {
			return nil, "", database.SpannerErrorToStatus(err)
		}

		resourceRow := &SpannerResourceRow[R]{
			key:           key,
			resourceTable: db,
		}

		// Unmarshal the resource from the row
		resource := spanner.NullProtoMessage{
			ProtoMessageVal: &{{ .ImportAlias }}.{{ .ResourceName }}{},
		}
		if err := row.ColumnByName("{{ .ResourceName }}", &resource); err != nil {
			return nil, "", database.SpannerErrorToStatus(err)
		}
		if resource.Valid {
			resourceRow.resource = resource.ProtoMessageVal.(R)
		}

		// Unmarshal the policy from the row
		policy := spanner.NullProtoMessage{
			ProtoMessageVal: &iampb.Policy{},
		}
		if err := row.ColumnByName("Policy", &policy); err != nil {
			return nil, "", database.SpannerErrorToStatus(err)
		}
		if policy.Valid {
			resourceRow.policy = policy.ProtoMessageVal.(*iampb.Policy)
		}

		resourceRows = append(resourceRows, resourceRow)
	}

	// If less than the limit is returned, there are more rows to read
	// TODO: Find a better way to determine if there are more rows to read.
	//  The current logic is flawed. It assume that if the number of rows returned is
	//  equal to the limit, there are more rows to read. This is not always the case.
	//  What if the final set of rows returned is exactly equal to the limit? For example,
	//  given a limit of 100 and total rows are 400, the fourth set of rows returned will
	//  be exactly 100 rows. The current logic will assume there are more rows to read.
	var nextPageToken string
	if len(resourceRows) == limit {
		offsetStr := fmt.Sprintf("%v", offset+int64(len(resourceRows)))
		nextPageToken = base64.StdEncoding.EncodeToString([]byte(offsetStr))
	}

	return resourceRows, nextPageToken, nil
}

