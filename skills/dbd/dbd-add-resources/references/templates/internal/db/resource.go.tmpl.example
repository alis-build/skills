func (db *{{ .CollectionId }}Table[R]) Delete(ctx context.Context, name string) error {
	rowKey := spanner.Key{name}

	// Create a mutation to delete the row
	mutation := spanner.Delete(db.tableName, rowKey)

	// Apply the mutation to Spanner
	if _, err := db.client.Apply(ctx, []*spanner.Mutation{mutation}); err != nil {
		return database.SpannerErrorToStatus(err)
	}

	return nil
}

func (db *{{ .CollectionId }}Table[R]) BatchDelete(ctx context.Context, names []string) error {
	if len(names) == 0 {
		return nil
	}

	// Create a slice of keys for the batch delete
	keySets := make([]spanner.KeySet, len(names))
	for i, name := range names {
		keySets[i] = spanner.Key{name}
	}

	// Create a mutation to delete the rows
	mutation := spanner.Delete(db.tableName, spanner.KeySets(keySets...))

	// Apply the mutation to Spanner
	if _, err := db.client.Apply(ctx, []*spanner.Mutation{mutation}); err != nil {
		return database.SpannerErrorToStatus(err)
	}

	return nil
}
