func (s *{{ .Service }}ServerType) Delete{{ .ResourceName }}Revision(ctx context.Context, req *{{ .ImportAlias }}.Delete{{ .ResourceName }}RevisionRequest) (*emptypb.Empty, error) {
	{{ if .HasPolicies }}
	// Create new IAM authorizer
	az, ctx, err := Iam.NewAuthorizer(ctx)
	if err != nil {
		return nil, status.Errorf(codes.Internal, "failed to create authorizer: %s", err.Error())
	}
	// Add user's policy to the authorizer
	az.AddIdentityPolicy()
    {{ end }}

	// VALIDATION
	validator := validation.NewValidator()
	validator.String("name", req.GetName()).IsPopulated().Matches(regex.{{ .ResourceName }}Revision)
	if err := validator.Validate(); err != nil {
		return nil, status.Error(codes.InvalidArgument, err.Error())
	}

	{{ if .HasPolicies }}
	// Get the parent policy
	{{ .ResourceId }}RevisionNamer, err := namers.{{ .ResourceName }}Revision(req.GetName())
	if err != nil {
		return nil, status.Errorf(codes.InvalidArgument, "invalid parent resource name: %s", err.Error())
	}
	parentPolicy, err := s.GetIamPolicy(ctx, &iampb.GetIamPolicyRequest{
		Resource: {{ .ResourceId }}RevisionNamer.{{ .ResourceName }}(),
	})
	if err != nil && status.Code(err) != codes.NotFound {
		return nil, err
	}
	// Add parent policy to the authorizer
	az.AddPolicy(parentPolicy)
    {{ end }}

	// Read the resource from the database
	row, err := db.{{ .ResourceName }}Revisions.Read(ctx, req.GetName())
	if err != nil {
		return nil, err
	}

    {{ if .HasPolicies }}
	// Check access
	az.AddPolicy(row.GetPolicy())
	if err = az.AuthorizeRpc(); err != nil {
		return nil, err
	}
    {{ end }}

	// Delete the resource
	if err = row.Delete(ctx); err != nil {
		return nil, err
	}

	return &emptypb.Empty{}, nil
}