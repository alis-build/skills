func (s *{{ .Service }}ServerType) GetIamPolicy(ctx context.Context, req *iampb.GetIamPolicyRequest) (*iampb.Policy, error) {
	// Create new IAM authorizer
	az, ctx, err := Iam.NewAuthorizer(ctx)
	if err != nil {
		return nil, status.Errorf(codes.Internal, "failed to create authorizer: %s", err.Error())
	}
	az.AddIdentityPolicy()

	// Get the resource's policy
	var policy *iampb.Policy

	// Switch to the correct resource type and read policy from db
    {{- range .Resources }}
    {{- if .HasPolicies }}
	if regex.{{ .ResourceName }}RegExp.MatchString(req.GetResource()) {
		row, err := db.{{ .ResourceNamePlural }}.Read(ctx, req.GetResource())
		if err != nil {
			return nil, err
		}
		policy = row.GetPolicy()
	}
    {{- end }}
    {{- end }}

	// Check access to Get IAM Policy
	az.AddPolicy(policy)
	err = az.AuthorizeRpc()
	if err != nil {
		return nil, err
	}

	// If no policy, return empty policy with random etag
	if policy == nil {
		return &iampb.Policy{Etag: []byte(uuid.New().String())}, nil
	}

	return policy, nil
}