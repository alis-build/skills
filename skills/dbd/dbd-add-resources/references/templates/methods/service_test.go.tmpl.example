var {{ .RootCollectionId }}Tester *testutils.GrpcServiceTester

func init() {
	{{ .RootCollectionId }}Tester = testutils.NewGrpcServiceTester(&{{ .ServiceImportAlias }}.{{ .Service }}_ServiceDesc, {{ .Service }}Server, unaryInterceptor)
	// {{ .RootCollectionId }}Tester.WithTestUser("123456789","johndoe@example.com")
}

