func Test{{ .Service }}ServerType_GetIamPolicy(t *testing.T) {
	type args struct {
		ctx context.Context
		req *iampb.GetIamPolicyRequest
	}
	tests := []struct {
		name    string
		args    args
		want    *iampb.Policy
		wantErr bool
	}{
		// TODO: Add test cases.
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			got, err := {{ .RootCollectionId }}Tester.Test(tt.args.ctx, tt.args.req, &iampb.Policy{})
			if (err != nil) != tt.wantErr {
				t.Errorf("GetIamPolicy() error = %v, wantErr %v", err, tt.wantErr)
				return
			}
			if !reflect.DeepEqual(got, tt.want) {
				t.Errorf("GetIamPolicy() got = %v, want %v", got, tt.want)
			}
		})
	}
}

