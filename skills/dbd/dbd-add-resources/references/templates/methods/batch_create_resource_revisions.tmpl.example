func (s *{{ .Service }}ServerType) BatchCreate{{ .ResourceName }}Revisions(ctx context.Context, req *{{ .ImportAlias }}.BatchCreate{{ .ResourceName }}RevisionsRequest) (*{{ .ImportAlias }}.BatchCreate{{ .ResourceName }}RevisionsResponse, error) {
	{{ if .HasPolicies }}
	// Create new IAM authorizer
	az, ctx, err := Iam.NewAuthorizer(ctx)
	if err != nil {
		return nil, status.Errorf(codes.Internal, "failed to create authorizer: %s", err.Error())
	}
	// Add user's policy to the authorizer
	az.AddIdentityPolicy()
    {{ end }}

	// VALIDATION
	validator := validation.NewValidator()
	validator.MessageIsPopulated("requests", req.GetRequests() != nil)
	validator.String("parent", req.GetParent()).IsPopulated().Matches(regex.{{ .ResourceName }})
	for i, request := range req.GetRequests() {
		validator.MessageIsPopulated(fmt.Sprintf("requests[%d]", i), request != nil)
		validator.MessageIsPopulated(fmt.Sprintf("requests[%d].{{ .ResourceId }}_revision", i), request.Get{{ .ResourceName }}Revision() != nil)
		validator.String(fmt.Sprintf("requests[%d].{{ .ResourceId }}_revision.name", i), request.Get{{ .ResourceName }}Revision().GetName()).IsPopulated().Matches(regex.{{ .ResourceName }}Revision)
		validator.MessageIsPopulated(fmt.Sprintf("requests[%d].{{ .ResourceId }}_revision.snapshot", i), request.Get{{ .ResourceName }}Revision().GetSnapshot() != nil)
		validator.String(fmt.Sprintf("requests[%d].{{ .ResourceId }}_revision.snapshot.name", i), request.Get{{ .ResourceName }}Revision().GetSnapshot().GetName()).IsPopulated().Matches(regex.{{ .ResourceName }})
		validator.String(fmt.Sprintf("requests[%d].parent", i), request.GetParent()).IsPopulated().Matches(regex.{{ .ResourceName }})
		// TODO: Add more validation rules here
	}
    // TODO: Add more validation rules here
	if err := validator.Validate(); err != nil {
		return nil, status.Error(codes.InvalidArgument, err.Error())
	}

	{{ if .HasParent }}
	// Ensure all requests have the same parent
	for _, request := range req.GetRequests() {
	 	if request.GetParent() != req.GetParent() {
			return nil, status.Errorf(codes.InvalidArgument, "all requests must have the same parent: %s", req.GetParent())
		}
	}
	{{ end }}

    {{ if .HasPolicies }}
	// Get the parent policy
	parentPolicy, err := s.GetIamPolicy(ctx, &iampb.GetIamPolicyRequest{
		Resource: req.GetParent(),
	})
	if err != nil && status.Code(err) != codes.NotFound {
		return nil, err
	}
	// Add parent policy to the authorizer
	az.AddPolicy(parentPolicy)
  
	if err = az.AuthorizeRpc(); err != nil {
		return nil, err
	}
    {{ end }}

	// Create a slice to hold the resources
	var resources []*{{ .ImportAlias }}.{{ .ResourceName }}Revision

    // Iterate over the requests and prepare the resources
	for _, request := range req.GetRequests() {
		// Generate a new UUID for the resource
		id := uuid.New().String()
		request.Get{{ .ResourceName }}Revision().Name = req.GetParent() + "/revisions/" + id		

        // Set the resource create and update time
		request.Get{{ .ResourceName }}Revision().CreateTime = timestamppb.Now()
		request.Get{{ .ResourceName }}Revision().UpdateTime = timestamppb.Now()

		
		// Append the resource to the respective list
		resources = append(resources, request.Get{{ .ResourceName }}Revision())
	}

	// Get the names of the resources to be created
	resourceNames := utils.Transform(req.GetRequests(), func(request *{{ .ImportAlias }}.Create{{ .ResourceName }}RevisionRequest) string {
		return request.Get{{ .ResourceName }}Revision().GetName()
	})

	// Write the resources to the database
	rows, err := db.{{ .ResourceName }}Revisions.BatchCreate(ctx, resourceNames, resources, nil)
	if err != nil {
		return nil, err
	}

	return &{{ .ImportAlias }}.BatchCreate{{ .ResourceName }}RevisionsResponse{
		{{ .ResourceName }}Revisions: utils.Transform(rows, func(row database.ResourceRow[*{{ .ImportAlias }}.{{ .ResourceName }}Revision]) *{{ .ImportAlias }}.{{ .ResourceName }}Revision {
			return row.GetResource()
		}),
	}, nil
}