terraform {
  required_providers {
    google = {
      source  = "hashicorp/google"
      version = "~> 7.0.0"
    }
    alis = {
      source  = "alis-exchange/alis"
      version = "2.0.0-beta3"
    }
  }
  backend "gcs" {
    bucket = "provided_at_runtime_by_alis"
    prefix = "provided_at_runtime_by_alis"
  }
}

provider "google-beta" {
  project = var.ALIS_OS_PROJECT
}

provider "google" {
  project = var.ALIS_OS_PROJECT
}

provider "alis" {
  project = var.ALIS_OS_PROJECT
}
