// Wire into agent main.go — add scheduler service, gRPC interceptor, and webscheduler sublauncher.
//
// Only the imports and sublaunchers marked REQUIRED are needed for the scheduler.
// Other sublaunchers (webui, api, lro, agui, a2a, agentengine) are independent —
// include them only if the agent uses them.

import (
	"REPLACE_WITH_YOUR_MODULE/internal/scheduler"                       // REQUIRED
	schedulerservice "go.alis.build/a2a/extension/scheduler/service"    // REQUIRED
	webscheduler "go.alis.build/adk/launchers/scheduler"                // REQUIRED
	launchersweb "go.alis.build/adk/launchers/web"
	"go.alis.build/mux"                                                 // REQUIRED
	"google.golang.org/adk/cmd/launcher/universal"
	"google.golang.org/grpc"                                            // REQUIRED
	// ... other launcher imports only if used ...
)

// Must match llmagent.Config.Name — passed as the first arg to webscheduler.NewLauncher.
const adkAppName = "REPLACE_WITH_ADK_APP_NAME"

func main() {
	ctx := context.Background()
	// ... agent config, session, memory ...

	// Scheduler service (Spanner + Cloud Tasks).
	scheduler.MustInitScheduler(ctx)

	// Create a new gRPC server and register the scheduler service interceptor.
	grpcServer := grpc.NewServer(grpc.UnaryInterceptor(schedulerservice.UnaryServerInterceptor()))
	// Register the gRPC server with the host mux.
	mux.HandleGRPC(grpcServer)

	// Only include sublaunchers the agent actually uses.
	// Scheduler requires: web + scheduler (with gRPC registrar).
	// webui, api, lro, agui, a2a, agentengine are independent.
	l := universal.NewLauncher(launchersweb.NewLauncher(
		// webagentengine.NewLauncher(agentEngineID),  // only if using Agent Engine
		// webui.NewLauncher(),                         // only if serving the ADK web UI
		// webapi.NewLauncher(),                        // only if using /api endpoints
		// weba2a.NewLauncher(),                        // only if using A2A protocol
		// weblro.NewLauncher(weblro.WithServiceID(lroServiceID), weblro.WithLROClient(tools.LRO)),
		// webagui.NewLauncher(aguiServiceID, webagui.WithCORS(webagui.CORSConfig{})),
		webscheduler.NewLauncher(adkAppName, scheduler.Service, webscheduler.WithGRPCRegistrar(grpcServer)), // REQUIRED
	))
	// l.Execute(ctx, launcherConfig, os.Args[1:])
}

// Deployment CLI args must include "scheduler" and "-app_name=<adkAppName>".
// Dockerfile: CMD ["/app/main", "web", "-port", "8080", "scheduler", "-app_name=REPLACE_WITH_ADK_APP_NAME"]
// Cloud Run:  args = ["web", "-port", "8080", "scheduler", "-app_name=REPLACE_WITH_ADK_APP_NAME"]
// Add other sublauncher args (webui, api, lro, agui) only if used.
